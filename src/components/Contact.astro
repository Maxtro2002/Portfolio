---
import type { TranslationSchema } from '../i18n/translations';

interface Props {
  t: TranslationSchema;
}

const { t } = Astro.props;
---

<section id="contact">
  <h2>{t.contact.title}</h2>
  <p>{t.contact.text}</p>
  <p>
    <strong>{t.contact.emailLabel}:</strong>
    <a href={`mailto:${t.contact.email}`}>{t.contact.email}</a>
  </p>
</section>

<style>
  p + p {
    margin-top: 0.5rem;
  }
</style>