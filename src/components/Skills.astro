---
import type { Locale, TranslationSchema } from '../i18n/translations';

interface Props {
  t: TranslationSchema;
  locale: Locale;
}

const { t } = Astro.props;
---

<section id="skills">
  <h2>{t.skills.title}</h2>
  <div class="skills-grid">
    {t.skills.items.map((skill) => (
      <article class="skill-card">
        <p>{skill}</p>
      </article>
    ))}
  </div>
</section>

<style>
  #skills {
    display: grid;
    gap: 0.85rem;
  }

  .skills-grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
  }

  .skill-card {
    border: 1px solid var(--border);
    border-radius: 0.7rem;
    padding: 0.75rem;
    background: color-mix(in srgb, var(--bg) 90%, var(--accent) 10%);
  }

  .skill-card p {
    font-weight: 700;
    text-align: center;
  }
</style>