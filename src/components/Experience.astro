---
import projectData from '../../data/projects/projects.json';
import type { Locale, TranslationSchema } from '../i18n/translations';

interface Props {
  t: TranslationSchema;
  locale: Locale;
}

const { t, locale } = Astro.props;
const source = locale === 'es' ? projectData.es : projectData.en;
const toAnchor = (value: string) =>
  value
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/(^-|-$)/g, '');
const copy =
  locale === 'es'
    ? {
        open: 'Ver mas',
        close: 'Cerrar',
        stack: 'Stack',
        detailsLabel: 'Detalle de experiencia',
      }
    : {
        open: 'See more',
        close: 'Close',
        stack: 'Stack',
        detailsLabel: 'Experience details',
      };
---

<section id="experience">
  <h2>{t.experience.title}</h2>

  <div class="experience-grid">
    {source.experience.map((job, index) => (
      <>
        <button
          type="button"
          class="experience-card"
          id={`experience-${toAnchor(`${job.company}-${job.role}`)}`}
          data-open-experience-dialog={`experience-dialog-${index}`}
        >
          <div class="header">
            <div>
              <h3>{job.company}</h3>
              <p class="role">{job.role}</p>
            </div>
            <time class="period">{job.period}</time>
          </div>

          <ul class="highlights">
            {job.highlights.slice(0, 2).map((highlight) => (
              <li>{highlight}</li>
            ))}
          </ul>

          <p class="cta">{copy.open}</p>
        </button>

        <dialog id={`experience-dialog-${index}`} aria-label={copy.detailsLabel}>
          <article class="dialog-content">
            <button
              type="button"
              class="dialog-close"
              data-close-experience-dialog
              aria-label={copy.close}
              title={copy.close}
            >
              X
            </button>

            <h3>{job.company}</h3>
            <p class="role">{job.role}</p>
            <p class="period dialog-period">{job.period}</p>

            <ul class="highlights dialog-highlights">
              {job.highlights.map((highlight) => (
                <li>{highlight}</li>
              ))}
            </ul>

            <p class="stack-title">{copy.stack}</p>
            <ul class="tech-stack">
              {[...new Set(job.techStack)].map((skill) => (
                <li>{skill}</li>
              ))}
            </ul>
          </article>
        </dialog>
      </>
    ))}
  </div>
</section>

<script is:inline>
  (() => {
    const lockScroll = () => {
      const current = Number(document.body.dataset.dialogOpenCount ?? '0');
      const next = current + 1;
      document.body.dataset.dialogOpenCount = String(next);
      document.body.style.overflow = 'hidden';
    };

    const unlockScroll = () => {
      const current = Number(document.body.dataset.dialogOpenCount ?? '0');
      const next = Math.max(0, current - 1);

      if (next === 0) {
        delete document.body.dataset.dialogOpenCount;
        document.body.style.overflow = '';
      } else {
        document.body.dataset.dialogOpenCount = String(next);
      }
    };

    const openButtons = document.querySelectorAll('[data-open-experience-dialog]');

    openButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const dialogId = button.getAttribute('data-open-experience-dialog');
        if (!dialogId) return;
        const dialog = document.getElementById(dialogId);
        if (dialog instanceof HTMLDialogElement && !dialog.open) {
          dialog.showModal();
          lockScroll();
        }
      });
    });

    const closeButtons = document.querySelectorAll('[data-close-experience-dialog]');

    closeButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const dialog = button.closest('dialog');
        if (dialog instanceof HTMLDialogElement) {
          dialog.close();
        }
      });
    });

    const dialogs = document.querySelectorAll('dialog[id^="experience-dialog-"]');

    dialogs.forEach((dialog) => {
      dialog.addEventListener('close', () => {
        unlockScroll();
      });

      dialog.addEventListener('click', (event) => {
        const bounds = dialog.getBoundingClientRect();
        const isInside =
          event.clientX >= bounds.left &&
          event.clientX <= bounds.right &&
          event.clientY >= bounds.top &&
          event.clientY <= bounds.bottom;

        if (!isInside) {
          dialog.close();
        }
      });
    });
  })();
</script>

<style>
  #experience {
    display: grid;
    gap: 0.85rem;
  }

  .experience-grid {
    display: grid;
    gap: 0.75rem;
  }

  .experience-card {
    width: 100%;
    text-align: left;
    border: 1px solid var(--border);
    border-radius: 0.8rem;
    padding: 0.9rem;
    background: color-mix(in srgb, var(--bg) 92%, var(--accent) 8%);
    cursor: pointer;
    transition: transform 0.18s ease, border-color 0.18s ease;
    scroll-margin-top: 6.5rem;
  }

  .experience-card:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--accent) 40%, var(--border) 60%);
  }

  .header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.6rem;
  }

  .experience-card h3 {
    margin: 0;
    font-size: 1.05rem;
  }

  .role {
    margin: 0.15rem 0 0;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .period {
    white-space: nowrap;
    font-size: 0.9rem;
    color: var(--muted);
  }

  .highlights {
    margin: 0.55rem 0 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.35rem;
  }

  .cta {
    margin-top: 0.7rem;
    font-weight: 600;
    color: var(--accent);
  }

  dialog {
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    width: min(680px, 92vw);
    border-radius: 1rem;
    padding: 0;
  }

  dialog::backdrop {
    background: rgba(5, 8, 15, 0.65);
  }

  .dialog-content {
    padding: 1rem;
    display: grid;
    gap: 0.75rem;
  }

  .dialog-close {
    justify-self: end;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--bg);
    color: var(--text);
    padding: 0.3rem 0.75rem;
    cursor: pointer;
  }

  .dialog-period {
    margin-top: -0.3rem;
  }

  .dialog-highlights {
    margin-top: 0;
  }

  .stack-title {
    font-size: 0.9rem;
    color: var(--muted);
  }

  .tech-stack {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tech-stack li {
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.25rem 0.55rem;
    font-size: 0.8rem;
  }
</style>