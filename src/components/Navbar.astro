---
import type { Locale, TranslationSchema } from '../i18n/translations';

interface Props {
  locale: Locale;
  t: TranslationSchema;
}

const { locale, t } = Astro.props;
---

<header>
  <nav>
    <a href="#about">{t.nav.about}</a>
    <a href="#experience">{t.nav.experience}</a>
    <a href="#skills">{t.nav.skills}</a>
    <a href="#projects">{t.nav.projects}</a>
    <a href="#contact">{t.nav.contact}</a>
    <details class="language-selector">
      <summary aria-label={t.nav.langLabel}>
        <span class="flag">{locale === 'es' ? '🇪🇸' : '🇺🇸'}</span>
        <span>{locale === 'es' ? 'Español' : 'English'}</span>
      </summary>
      <div class="language-menu" role="menu" aria-label={t.nav.langLabel}>
        <a href="/es" class={locale === 'es' ? 'active' : ''} role="menuitem">
          <span class="flag">🇪🇸</span>
          <span>Español</span>
        </a>
        <a href="/en" class={locale === 'en' ? 'active' : ''} role="menuitem">
          <span class="flag">🇺🇸</span>
          <span>English</span>
        </a>
      </div>
    </details>
    <button type="button" data-theme-toggle aria-label="Cambiar tema"></button>
  </nav>
</header>

<script is:inline>
  const button = document.querySelector('[data-theme-toggle]');
  const root = document.documentElement;

  const getThemeLabel = () => (root.dataset.theme === 'dark' ? 'Tema: oscuro' : 'Tema: claro');

  const syncButton = () => {
    if (!button) return;
    button.textContent = getThemeLabel();
  };

  if (!root.dataset.theme) {
    root.dataset.theme = 'dark';
    root.style.colorScheme = 'dark';
  }

  syncButton();

  button?.addEventListener('click', () => {
    const nextTheme = root.dataset.theme === 'dark' ? 'light' : 'dark';
    root.dataset.theme = nextTheme;
    root.style.colorScheme = nextTheme;
    localStorage.setItem('theme', nextTheme);
    syncButton();
  });
</script>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(6px);
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    border-bottom: 1px solid var(--border);
  }

  nav {
    width: min(100% - 2rem, var(--container));
    margin-inline: auto;
    min-height: 64px;
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    padding-block: 0.8rem;
  }

  a {
    font-weight: 600;
    text-decoration: none;
  }

  .language-selector {
    margin-left: auto;
    position: relative;
  }

  .language-selector summary {
    list-style: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    border-radius: 999px;
    padding: 0.5rem 0.85rem;
    cursor: pointer;
    user-select: none;
  }

  .language-selector summary::-webkit-details-marker {
    display: none;
  }

  .language-menu {
    position: absolute;
    right: 0;
    top: calc(100% + 0.4rem);
    min-width: 7.5rem;
    display: grid;
    gap: 0.15rem;
    padding: 0.3rem;
    border: 1px solid var(--border);
    background: var(--surface);
    border-radius: 0.8rem;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.15);
    z-index: 20;
  }

  .language-menu a {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.7rem;
    border-radius: 0.55rem;
    color: var(--text);
  }

  .language-menu a:hover {
    background: color-mix(in srgb, var(--bg) 85%, var(--accent) 15%);
  }

  .language-menu a.active {
    background: color-mix(in srgb, var(--accent) 20%, transparent);
  }

  .flag {
    display: inline-block;
    font-size: 1.15rem;
    line-height: 1;
    font-family: 'Apple Color Emoji', 'Segoe UI Emoji', 'Segoe UI Symbol', 'Noto Color Emoji', sans-serif;
  }

  button {
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    border-radius: 999px;
    padding: 0.5rem 0.85rem;
    cursor: pointer;
  }
</style>