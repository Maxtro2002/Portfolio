---
import type { Locale, TranslationSchema } from '../i18n/translations';

interface Props {
  locale: Locale;
  t: TranslationSchema;
}

const { locale, t } = Astro.props;
---

<header>
  <nav>
    <a href="#about">{t.nav.about}</a>
    <a href="#skills">{t.nav.skills}</a>
    <a href="#projects">{t.nav.projects}</a>
    <a href="#experience">{t.nav.experience}</a>
    <a href="#contact">{t.nav.contact}</a>
    <label class="language-selector">
      <span>{t.nav.langLabel}</span>
      <select data-language-select value={locale} aria-label={t.nav.langLabel}>
        <option value="es">🇪🇸 Espanol</option>
        <option value="en">🇺🇸 English</option>
      </select>
    </label>
    <button type="button" data-theme-toggle aria-label="Cambiar tema"></button>
  </nav>
</header>

<script is:inline>
  const button = document.querySelector('[data-theme-toggle]');
  const languageSelect = document.querySelector('[data-language-select]');
  const root = document.documentElement;

  const getThemeLabel = () => (root.dataset.theme === 'dark' ? 'Tema: oscuro' : 'Tema: claro');

  const syncButton = () => {
    if (!button) return;
    button.textContent = getThemeLabel();
  };

  if (!root.dataset.theme) {
    root.dataset.theme = 'dark';
    root.style.colorScheme = 'dark';
  }

  syncButton();

  button?.addEventListener('click', () => {
    const nextTheme = root.dataset.theme === 'dark' ? 'light' : 'dark';
    root.dataset.theme = nextTheme;
    root.style.colorScheme = nextTheme;
    localStorage.setItem('theme', nextTheme);
    syncButton();
  });

  languageSelect?.addEventListener('change', (event) => {
    const target = event.target;
    if (!(target instanceof HTMLSelectElement)) return;

    const url = new URL(window.location.href);
    url.searchParams.set('lang', target.value);
    window.location.href = url.toString();
  });
</script>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(6px);
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    border-bottom: 1px solid var(--border);
  }

  nav {
    width: min(100% - 2rem, var(--container));
    margin-inline: auto;
    min-height: 64px;
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    padding-block: 0.8rem;
  }

  a {
    font-weight: 600;
    text-decoration: none;
  }

  .language-selector {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-weight: 600;
  }

  .language-selector select {
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    border-radius: 999px;
    padding: 0.45rem 0.75rem;
    cursor: pointer;
  }

  button {
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    border-radius: 999px;
    padding: 0.5rem 0.85rem;
    cursor: pointer;
  }
</style>